# Rust build artifacts
target/
*.pdb
*.ilk
*.lib

# Crash outputs (generated)
crashes/
*.crash
*.dmp

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Python
__pycache__/
*.py[cod]
*.pyo
venv/
.venv/

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Driver binaries (legal issues)
*.sys

# Compiled executables (rebuild from source)
# Exclude build artifacts, but allow release binaries
target/
*.pdb
*.ilk

# Allow release binaries for distribution
!releases/*.exe
!executor.exe
!controller.exe
!ladybug.exe

# Logs and temp
*.log
*.tmp
*.temp

# Sensitive / generated data
*.last_run_timestamp
kernel_addresses.txt

# Setup scripts (don't need these in repo)
push_to_github.ps1
setup_github.ps1

# Secrets and credentials - NEVER COMMIT THESE
.env
.env.*
*.env
secrets/
secrets.*
*secret*
*password*
*credential*
*.pem
*.key
*.p12
*.pfx
*_token*
*_api_key*
config.local.*
settings.local.*